[submodule "home/.vim/pack/tpope/start/repeat"]
	path = home/.vim/pack/tpope/start/repeat
	url = https://tpope.io/vim/repeat.git
[submodule "home/.vim/pack/tpope/start/surround"]
	path = home/.vim/pack/tpope/start/surround
	url = https://tpope.io/vim/surround.git
[submodule "home/.bashrc.d/bash-git-prompt"]
	path = home/.bashrc.d/bash-git-prompt
	url = https://github.com/magicmonty/bash-git-prompt.git
[submodule "home/bin/bin/ical2org"]
	path = home/bin/bin/ical2org
	url = https://github.com/msherry/ical2org.git
[submodule "home/.zshrc.d/fzf-tab"]
	path = home/.zshrc.d/fzf-tab
	url = https://github.com/Aloxaf/fzf-tab.git
